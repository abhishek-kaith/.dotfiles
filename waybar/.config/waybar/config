{
  "layer": "top",
  "position": "top",
  "mod": "dock",
  "exclusive": true,
  "passthrough": false,
  "gtk-layer-shell": true,
  "height": 40,
  "margin-top": 2,


  "modules-left": [
    "custom/launch_wofi",
    "hyprland/workspaces",
    "wlr/taskbar",
    "hyprland/window"
  ],
  "modules-center": [
    //"idle_inhibitor",
    "clock"
  ],
  "modules-right": [
    //"network",
    //"custom/weather",
    "cpu",
    "memory",
    "disk",
    "temperature",
    "backlight",
    "pulseaudio",
    "pulseaudio#microphone",
    "battery",
    "tray",
    "custom/power_btn"
  ],

  "custom/launch_wofi": {
    "format": " пЊѓ ",
    "on-click": "wofi",
    "tooltip": false
    },

  "hyprland/window": {
      "format": "{}"
  },

   "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": " п€…  on",
            "deactivated": " п€„ "
        },
        "tooltip": true
    },

  "wlr/taskbar": {
      "format": "{icon}",
      "icon-size": 24,
      "all-outputs": true,
      "tooltip-format": "{name}",
      "on-click": "activate",
      "on-click-middle": "close",
      "ignore-list": [
          "wofi",
          "alacritty"
      ],
      "app_ids-mapping": {
          "steam_app_39210": "Final Fantasy 14"
      }
  },

  "cpu": {
    "interval": 10,
    "format": "п’ј  {usage}%",
    "max-length": 10,
    "on-click": "alacritty --start-as=fullscreen --title btop sh -c 'btop'"
  },

  "memory": {
    "interval": 30,
    "format": "п‹›  {}%",
    "max-length": 10,
    "tooltip": true,
    "tooltip-format": "Memory - {used:0.1f}GB used",
    "on-click": "alacritty --start-as=fullscreen --title btop sh -c 'btop'"
  },

  "disk": {
    "interval": 30,
    "format": "у°‹Љ  {percentage_used}%",
    "path": "/",
    "tooltip": true,
    "tooltip-format": "HDD - {used} used out of {total} on {path} ({percentage_used}%)",
    "on-click": "alacritty --start-as=fullscreen --title btop sh -c 'btop'"
  },

  "temperature": {
    "thermal-zone": 1,
      "format": "п‹‰",
      "format": "п‹‰ {temperatureC}В°C",
      "critical-threshold": 50,
      "format-critical": "п‹‡ {temperatureC}В°C",
      "on-click": "alacritty --start-as=fullscreen --title btop sh -c 'btop'"
  },

  "network": {
    "interface": "wlan0",
    "interval": 1,
    "format": "пѓ­  {bandwidthDownBytes}  пѓ®  {bandwidthUpBytes}",
    "format-disconnected": " у°ћѓ ",
    "tooltip": false
  },

  "tray": {
    "icon-size": 22,
    "spacing": 10
  },

  "backlight": {
    "device": "intel_backlight",
    "format": "{icon} {percent}%",
    "format-icons": ["у°ѓћ", "у°ѓќ", "у°ѓџ", "у°ѓ "],
    "on-scroll-up": "~/.config/waybar/scripts/brightness --inc",
    "on-scroll-down": "~/.config/waybar/scripts/brightness --dec",
    "min-length": 6
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "у°–Ѓ ",
    "on-click": "~/.config/waybar/scripts/volume --toggle",
    "on-click-right": "pavucontrol",
    "on-scroll-up": "~/.config/waybar/scripts/volume --inc",
    "on-scroll-down": "~/.config/waybar/scripts/volume --dec",
    "scroll-step": 1,
    "format-icons": {
      "headphone": "пЂҐ ",
      "hands-free": "пЂҐ ",
      "headset": "пЂҐ ",
      "phone": "п‚• ",
      "portable": "п‚• ",
      "car": "п†№ ",
      "default": ["пЂ¦", "пЂ§", "пЂЁ", "пЂЁ"]
      }
    },

    "pulseaudio#microphone": {
      "format": "{format_source}",
      "format-source": "п„° {volume}%",
      "format-source-muted": "п„±",
      "on-click": "~/.config/waybar/scripts/volume --toggle-mic",
      "on-click-right": "pavucontrol",
      "on-scroll-up": "~/.config/waybar/scripts/volume --mic-inc",
      "on-scroll-down": "~/.config/waybar/scripts/volume --mic-dec",
      "scroll-step": 5
    },

    "battery": {
      "states": {
          "good": 95,
          "warning": 30,
          "critical": 20
    },
      "format": "{icon} {capacity}%",
      "format-charging": "у°‰Ѓ {capacity}%",
      "format-plugged": "у°‰Ѓ {capacity}%",
      "format-icons": ["у°‚Ћ", "у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚", "у°Ѓ№"],
	"tooltip": false
    },


    //"custom/power_btn": {
    //  "format": "пЂ‘  ",
    // "on-click": "sh -c '(sleep 0.5s; wlogout --protocol layer-shell)' & disown",
    //  "tooltip": false
    //},

    "clock": {
    "interval": 1,
      "format": "{:у°Ґ”  %I:%M:%S %p}",
      "tooltip-format": "{:пЃі  %A, %d-%m-%Y}",
      "format-alt": "{:у°ё— %e %B %Y}"
    },

     "hyprland/workspaces": {
   	 "active-only": false,
    	"all-outputs": false,
   	 "format": "{icon}",
     "format-icons": {
       "active": "у±љҐ",
       "default": "у± ‡",
     },
    	"show-special": true
    },

    "custom/workspaces": {
      "format": "{icon}",
      "format-icons": {
          "active": "у°Ђ‰",
          "default": "п„‘",
          "urgent": "у°ЂЁ",
          },
    "persistent-workspaces": {
        "*": 4
          }
    },

    "custom/weather": {
      "exec": "curl -s 'https://wttr.in/repalle?format=2' | tr -d ' '",
      "tooltip": false,
      "interval": 900
    }
}
